fun portero(numero)
{
  posi[0]=20;
  posi[1]=180;
  
  dball=distance(mine(numero,x),mine(numero,y),ball(),ball(y));
  dini= distance(mine(numero,x),mine(numero,y),posi[0],posi[1]);
 
 goto(numero,posi[0],posi[1]);  
 
}
  
  
for(i=1;i<11;i++)
{ 
  if(distance(mine(i,x),mine(i,y),ball(x),ball(y))<=25)
       shoot(i,0);
  else
     goto(i,ball(),ball(y)) ;
}


portero(0);